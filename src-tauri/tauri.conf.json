{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Amendoim",
  "version": "1.1.7",
  "identifier": "sc.linhares.amendoim",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Amendoim",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2QzI4NzRBMUYxMTBDQgpSV1RMRVBHaGRDaHNENHlKaHc3SGpQWHJ6WmdBQlBWZnVYTFRnMEE4c05DSjc5dWl0VExLbEJ6Zwo=",
      "endpoints": [
        "https://github.com/gufao/amendoim/releases/latest/download/latest.json"
      ]
    }
  }
}
